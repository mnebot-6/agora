# Plantilla — copia este archivo a `keystore.properties` (en la raíz del repo)
# y rellena con los datos reales del keystore de release.
#
# `keystore.properties` ESTÁ en .gitignore — nunca debe commitearse.
#
# Generación del keystore (ejecutar UNA SOLA VEZ y guardarlo en lugar seguro
# + backup cifrado fuera del repo):
#
#   keytool -genkey -v \
#     -keystore agora-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias agora
#
# Tras subir el primer .aab a Play Console, activa "Play App Signing" para
# que Google guarde la clave de firma de la app y tú solo gestiones el
# upload key. ⚠ Si pierdes el keystore SIN haber activado Play App Signing,
# no podrás volver a actualizar la app en Play. NUNCA.

storeFile=../agora-release.jks
storePassword=CHANGE_ME
keyAlias=agora
keyPassword=CHANGE_ME
